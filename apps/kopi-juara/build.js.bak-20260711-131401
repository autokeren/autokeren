import * as esbuild from "esbuild";
import fs from "node:fs/promises";

await esbuild.build({
  entryPoints: ["src/index.js"],
  bundle: true,
  format: "esm",
  platform: "neutral",
  target: "es2022",
  outfile: "dist/worker.js",
  minify: false,
  sourcemap: false,
});

const stats = await fs.stat("dist/worker.js");
console.log(`Built dist/worker.js (${stats.size} bytes)`);
