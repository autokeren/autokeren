"""PlanExecutor — eksekusi sub-tasks via agent, handle retry & dynamic replan."""
from __future__ import annotations

import time
from dataclasses import dataclass
from typing import Any, Callable

from autokeren.autoplan.decomposer import GoalDecomposer, SubTask
from autokeren.autoplan.tracker import PlanTracker, TaskStatus


@dataclass
class ExecutionResult:
    """Hasil eksekusi satu sub-task."""
    task_id: str
    success: bool
    output: str = ""
    error: str = ""
    duration: float = 0.0
    retries: int = 0

    def to_dict(self) -> dict[str, Any]:
        return {
            "task_id": self.task_id,
            "success": self.success,
            "output": self.output[:500],
            "error": self.error[:500],
            "duration": round(self.duration, 1),
            "retries": self.retries,
        }


class PlanExecutor:
    """Orchestrate eksekusi sub-tasks secara otonom."""

    def __init__(
        self,
        agent: Any,
        router: Any = None,
        max_retries_per_task: int = 2,
        on_task_start: Callable[[SubTask], None] | None = None,
        on_task_done: Callable[[SubTask, ExecutionResult], Any] | None = None,
        on_progress: Callable[[str], None] | None = None,
    ) -> None:
        self.agent = agent
        self.router = router
        self.max_retries_per_task = max_retries_per_task
        self.on_task_start = on_task_start
        self.on_task_done = on_task_done
        self.on_progress = on_progress
        self._decomposer = GoalDecomposer(router=router)
        self.results: list[ExecutionResult] = []

    def execute_plan(self, goal: str, context: str = "") -> PlanTracker:
        """Decompose goal, eksekusi semua sub-tasks, return tracker."""
        tasks = self._decomposer.decompose(goal, context)
        if not tasks:
            self._log("Gagal decomposition, eksekusi langsung.")
            tasks = [SubTask(id="t1", title=goal, description="Eksekusi langsung.")]

        tracker = PlanTracker(tasks=tasks)
        self._log(f"Plan dibuat: {tracker.summary()}")

        while not tracker.all_done():
            ready = tracker.get_ready_tasks()
            if not ready:
                self._log("Tidak ada task ready. Selesai.")
                break

            task = ready[0]
            result = self._execute_task(task, tracker)

            if result.success:
                tracker.set_status(task.id, TaskStatus.DONE)
                self._log(f"✅ {task.id} done: {task.title}")
            else:
                task.attempts += 1
                if task.attempts <= self.max_retries_per_task:
                    tracker.set_status(task.id, TaskStatus.PENDING)
                    self._log(f"🔄 {task.id} retry ({task.attempts}/{self.max_retries_per_task})")
                else:
                    tracker.set_status(task.id, TaskStatus.FAILED)
                    self._log(f"❌ {task.id} failed after {task.attempts} attempts")

                    # Dynamic replan: pecah task yang failed jadi sub-tasks lebih kecil
                    if self.router and task.attempts >= self.max_retries_per_task:
                        self._replan(task, tracker)

        self._log(f"Plan selesai: {tracker.summary()} | Progress: {tracker.progress_pct()}%")
        return tracker

    def _execute_task(self, task: SubTask, tracker: PlanTracker) -> ExecutionResult:
        """Eksekusi satu sub-task via agent.run()."""
        tracker.set_status(task.id, TaskStatus.IN_PROGRESS)
        if self.on_task_start:
            self.on_task_start(task)

        prompt = self._build_prompt(task)
        start = time.time()

        try:
            resp = self.agent.run(prompt)
            output = resp.content or ""
            duration = time.time() - start

            success = self._evaluate_success(task, output)
            result = ExecutionResult(
                task_id=task.id,
                success=success,
                output=output,
                duration=duration,
                retries=task.attempts,
            )
        except Exception as e:
            duration = time.time() - start
            result = ExecutionResult(
                task_id=task.id,
                success=False,
                error=str(e),
                duration=duration,
                retries=task.attempts,
            )

        task.result = result.output
        self.results.append(result)
        if self.on_task_done:
            self.on_task_done(task, result)
        return result

    def _build_prompt(self, task: SubTask) -> str:
        """Build prompt untuk agent berdasarkan sub-task."""
        parts = [f"Task: {task.title}"]
        if task.description:
            parts.append(f"\nDeskripsi: {task.description}")
        if task.success_criteria:
            parts.append(f"\nKriteria sukses: {task.success_criteria}")
        parts.append(
            "\n\nEksekusi task ini sampai selesai. Gunakan tool yang tersedia. "
            "Jelaskan hasil singkat di akhir."
        )
        return "\n".join(parts)

    def _evaluate_success(self, task: SubTask, output: str) -> bool:
        """Evaluate task output terhadap success_criteria.

        Preferensi: gunakan LLM-based evaluator kalau router tersedia.
        Fallback ke heuristic keyword count kalau tidak.
        """
        if not task.success_criteria:
            return self._heuristic_evaluate_success(output)

        if self.router:
            try:
                return self._llm_evaluate_success(task, output)
            except Exception:
                pass
        return self._heuristic_evaluate_success(output)

    def _llm_evaluate_success(self, task: SubTask, output: str) -> bool:
        """Minta LLM menilai apakah success_criteria terpenuhi berdasarkan output."""
        prompt = f"""Kamu adalah evaluator ketat. Evaluasi apakah task berikut BERHASIL sesuai kriteria.

TASK: {task.title}
DESKRIPSI: {task.description}
KRITERIA SUKSES: {task.success_criteria}

OUTPUT HASIL EKSEKUSI:
---
{output[:4000]}
---

Pertanyaan: Apakah kriteria sukses terpenuhi? Jawab HANYA dengan "YES" atau "NO", lalu satu kalimat alasan singkat.
"""
        resp = self.router.complete(
            [{"role": "user", "content": prompt}],
            max_tokens=256,
            temperature=0.0,
        )
        answer = (resp.content or "").strip().lower()
        return answer.startswith("yes")

    def _heuristic_evaluate_success(self, output: str) -> bool:
        """Heuristic eval: kalau ada banyak error keyword, anggap gagal."""
        fail_keywords = ["error:", "failed", "gagal", "exception:", "traceback", "cannot", "unable to"]
        output_lower = output.lower()
        fail_count = sum(1 for kw in fail_keywords if kw in output_lower)
        # Kalau lebih dari 2 fail keywords, kemungkinan gagal
        return fail_count <= 2

    def _replan(self, failed_task: SubTask, tracker: PlanTracker) -> None:
        """Dynamic replan: pecah failed task jadi sub-tasks lebih kecil."""
        self._log(f"🔁 Replanning task {failed_task.id}: {failed_task.title}")
        sub_tasks = self._decomposer.decompose(
            goal=failed_task.title,
            context=f"Task sebelumnya gagal. {failed_task.description}",
        )
        if not sub_tasks or len(sub_tasks) <= 1:
            return

        # Insert sub-tasks baru ke tracker, mark original as skipped
        tracker.set_status(failed_task.id, TaskStatus.SKIPPED)
        for st in sub_tasks:
            st.id = f"{failed_task.id}_{st.id}"
            st.depends_on = [f"{failed_task.id}_{d}" for d in st.depends_on]
            tracker.tasks.append(st)
            tracker._status[st.id] = TaskStatus.PENDING
        self._log(f"Replan: {len(sub_tasks)} sub-tasks baru dari {failed_task.id}")

    def _log(self, msg: str) -> None:
        if self.on_progress:
            self.on_progress(msg)
